#!/usr/bin/env bash
# =============================================================================
# mcphe — mcphe Test Runner
# =============================================================================
# Usage:
#   mcphe [OPTIONS] [COMMAND...]
#
# Options:
#   -t, --type    Test type: positive, negative, all  (default: all)
#   -p, --provider  Provider filter: ollama, lmstudio, openai, remote, any (default: any)
#   -c, --command   Command filter: chat, model, embed, version, etc. (default: all)
#   -d, --dry-run   Print what would run without executing
#   -v, --verbose   Verbose output (set -x in sub-scripts)
#   -s, --stop      Stop on first failure
#   -h, --help      Show this help
#
# Examples:
#   mcphe                          # Run all tests
#   mcphe -t positive              # Only positive tests
#   mcphe -t negative              # Only negative tests

# =============================================================================

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
COMMAND_SCRIPTS_PATH="${SCRIPT_DIR}/command-scripts"
RESULTS_DIR="${SCRIPT_DIR}/results"
LOG_FILE="${RESULTS_DIR}/mcphe-$(date +%Y%m%d-%H%M%S).log"

# ---- Defaults ----
OPT_TYPE="all"
OPT_PROVIDER="default.yaml"
OPT_COMMANDS="all"
OPT_DRY_RUN=false
OPT_VERBOSE=false
OPT_STOP=false

# ---- Counters ----
TESTS_RUN=0
TESTS_PASSED=0
TESTS_FAILED=0
TESTS_SKIPPED=0

# ---- Colors ----
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

usage() {
    sed -n '/^# Usage/,/^# ===/{ /^# ===/d; s/^# \?//; p }' "$0"
    exit 0
}

log() { echo -e "$*" | tee -a "${LOG_FILE}"; }
log_section() { log "\n${BOLD}${BLUE}══════════════════════════════════════════${NC}"; log "${BOLD}${BLUE}  $*${NC}"; log "${BOLD}${BLUE}══════════════════════════════════════════${NC}"; }
log_pass() { log "${GREEN}  ✓ PASS${NC}  $*"; }
log_fail() { log "${RED}  ✗ FAIL${NC}  $*"; }
log_skip() { log "${YELLOW}  ⊘ SKIP${NC}  $*"; }
log_info() { log "${CYAN}  ℹ${NC}  $*"; }

# ---- Argument parsing ----
while [[ $# -gt 0 ]]; do
    case "$1" in
        -t|--type)      OPT_TYPE="$2";     shift 2 ;;
        -p|--provider)  OPT_PROVIDER="$2"; shift 2 ;;
        -c|--command)   OPT_COMMANDS="$2"; shift 2 ;;
        -d|--dry-run)   OPT_DRY_RUN=true;  shift ;;
        -v|--verbose)   OPT_VERBOSE=true;  shift ;;
        -s|--stop)      OPT_STOP=true;     shift ;;
        -h|--help)      usage ;;
        *)              echo "Unknown option: $1"; usage ;;
    esac
done

# ---- Setup ----
mkdir -p "${RESULTS_DIR}"
source "${SCRIPT_DIR}/funcs.sh"

export OPT_PROVIDER

# Check provider availability
if ! $OPT_DRY_RUN; then
    if ! port_available; then
        log_fail "Port '${OPT_PROVIDER}' is not reachable. Check it is running."
        exit 1
    fi
fi

# ---- Build list of scripts to run ----
declare -a SCRIPTS_TO_RUN=()

collect_scripts() {
    local type_filter="$1"   # positive, negative, all
    local cmd_filter="$2"    # all or space-separated list

    local patterns=()
    case "${type_filter}" in
        positive)   patterns=("*+.sh") ;;
        negative)   patterns=("*-.sh") ;;
        all)        patterns=("*+.sh" "*-.sh") ;;
    esac

    for pattern in "${patterns[@]}"; do
        for script in "${COMMAND_SCRIPTS_PATH}"/${pattern}; do
            [[ -f "$script" ]] || continue
            local basename
            basename="$(basename "$script")"
            # Strip +.sh or -.sh to get command name
            local cmdname="${basename%+.sh}"
            cmdname="${cmdname%-.sh}"

            if [[ "${cmd_filter}" == "all" ]]; then
                SCRIPTS_TO_RUN+=("$script")
            else
                for cmd in ${cmd_filter}; do
                    if [[ "${cmdname}" == "${cmd}" ]]; then
                        SCRIPTS_TO_RUN+=("$script")
                        break
                    fi
                done
            fi
        done
    done
}

collect_scripts "${OPT_TYPE}" "${OPT_COMMANDS}"

if [[ ${#SCRIPTS_TO_RUN[@]} -eq 0 ]]; then
    log_fail "No test scripts matched filters: type=${OPT_TYPE} provider=${OPT_PROVIDER} commands=${OPT_COMMANDS}"
    exit 1
fi

# ---- Run ----
START_TIME=$(date +%s)

log_section "mcphe Test Suite  $(date '+%Y-%m-%d %H:%M:%S')"
log_info "Type:     ${OPT_TYPE}"
log_info "Provider: ${OPT_PROVIDER}"
log_info "Commands: ${OPT_COMMANDS}"
log_info "Scripts:  ${#SCRIPTS_TO_RUN[@]}"
log_info "Log:      ${LOG_FILE}"

[[ "$OPT_DRY_RUN" == "true" ]] && log_info "${YELLOW}DRY RUN — no tests will actually execute${NC}"

run_script() {
    local script="$1"
    local label
    label="$(basename "$script")"

    TESTS_RUN=$((TESTS_RUN + 1))

    if $OPT_DRY_RUN; then
        log_skip "${label} (dry-run)"
        TESTS_SKIPPED=$((TESTS_SKIPPED + 1))
        return 0
    fi

    local extra_args=""
    $OPT_VERBOSE && extra_args="-x"

    log "\n${BOLD}▶ ${label}${NC}"

    local tmp_out
    tmp_out=$(mktemp -t mcphe-test-XXXXXXXX.log)
    local exit_code=0

    # Determine if this is a positive or negative test
    local is_negative=false
    [[ "$script" == *"-.sh" ]] && is_negative=true

    if $is_negative; then
        # Negative tests: we run each test case inside and collect any that UNEXPECTEDLY pass
        bash ${extra_args} "$script" 2>&1 | tee -a "${LOG_FILE}" "${tmp_out}"
        # Negative scripts should exit non-zero overall (at least one error expected)
        # We don't fail the runner on them — they are expected to produce errors
        log_pass "${label} (negative test completed — review output above)"
        TESTS_PASSED=$((TESTS_PASSED + 1))
    else
        if bash ${extra_args} "$script" >> "${tmp_out}" 2>&1; then
            cat "${tmp_out}" | tee -a "${LOG_FILE}"
            log_pass "${label}"
            TESTS_PASSED=$((TESTS_PASSED + 1))
        else
            exit_code=$?
            cat "${tmp_out}" | tee -a "${LOG_FILE}"
            log_fail "${label} (exit code ${exit_code})"
            TESTS_FAILED=$((TESTS_FAILED + 1))
            if $OPT_STOP; then
                log "\n${RED}Stopping on first failure (--stop set)${NC}"
                rm -f "${tmp_out}"
                summary
                exit 1
            fi
        fi
    fi
    rm -f "${tmp_out}"
}

summary() {
    local END_TIME
    END_TIME=$(date +%s)
    local ELAPSED=$((END_TIME - START_TIME))

    log_section "Results"
    log "  Total:   ${TESTS_RUN}"
    log "  ${GREEN}Passed:  ${TESTS_PASSED}${NC}"
    log "  ${RED}Failed:  ${TESTS_FAILED}${NC}"
    log "  ${YELLOW}Skipped: ${TESTS_SKIPPED}${NC}"
    log "  Elapsed: ${ELAPSED}s"
    log "  Log:     ${LOG_FILE}"

    if [[ ${TESTS_FAILED} -gt 0 ]]; then
        log "\n${RED}${BOLD}SUITE FAILED${NC}"
        return 1
    else
        log "\n${GREEN}${BOLD}SUITE PASSED${NC}"
        return 0
    fi
}

for script in "${SCRIPTS_TO_RUN[@]}"; do
    run_script "$script"
done

summary
